{
  "name": "@allstak/react-native",
  "version": "0.1.4",
  "description": "AllStak React Native SDK — standalone error tracking, breadcrumbs, network capture, and ErrorUtils + Hermes rejection hooks. No browser or Node dependencies. Native Android/iOS crash modules in ./native.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "native",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/allstak-io/allstak-react-native.git"
  },
  "homepage": "https://allstak.sa",
  "bugs": {
    "url": "https://github.com/allstak-io/allstak-react-native/issues"
  },
  "keywords": [
    "allstak",
    "observability",
    "react-native",
    "mobile",
    "error-tracking",
    "apm"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --platform neutral --external react-native --external promise/setimmediate/rejection-tracking",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 test/*.test.mjs"
  },
  "peerDependencies": {
    "react-native": ">=0.70"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
